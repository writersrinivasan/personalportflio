# ─────────────────────────────────────────────────────────────────
# Environment Variables — Srinivasan Ramanujam Website
#
# HOW TO USE:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in the real values in .env.local
#   3. NEVER commit .env.local to git (it's in .gitignore)
#   4. Add these same variables in Vercel/Netlify dashboard before deploying
# ─────────────────────────────────────────────────────────────────

# ── Site URL (no trailing slash) ─────────────────────────────────
# Used in sitemap.ts and any absolute URL generation
NEXT_PUBLIC_SITE_URL=https://srinivasanramanujam.com

# ── Booking Form (choose ONE service and fill its key) ───────────

# Option A: Formspree
# Get your form ID at https://formspree.io → create a new form
NEXT_PUBLIC_FORMSPREE_ID=

# Option B: EmailJS
# Get these from https://www.emailjs.com → Account → API Keys
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# ── Analytics (optional — add after launch) ──────────────────────

# Option A: Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Option B: Plausible Analytics (privacy-friendly, no cookie banner needed)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
